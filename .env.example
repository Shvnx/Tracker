# MySQL connection details from freesqldatabase.com
DB_HOST=your-db-host.freesqldatabase.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# How often to poll the platform API, in seconds
POLL_INTERVAL_SECONDS=60

# A secret key the frontend must send to control tracking (simple protection)
APP_SECRET=change-this-to-something-random

PORT=3000
